# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (for embeddings only)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Claude models (defaults shown — override if needed)
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Trello (required for pipeline dashboard)
TRELLO_API_KEY=...
TRELLO_TOKEN=...
TRELLO_BOARD_ID=...

# Paths — set to your local checkouts
AUTOMATION_CODEBASE_PATH=/path/to/aupost-test-automation
BACKEND_CODE_PATH=/path/to/aupost-backend
FRONTEND_CODE_PATH=/path/to/aupost-frontend
WIKI_PATH=/path/to/aupost-wiki

# Google Sheets — AU Post test cases
